{
  "name": "@webrtc-node/stats",
  "version": "0.2.1",
  "description": "Transport statistics snapshots and sampling for @webrtc-node/webrtc peer connections.",
  "author": "webrtc-node contributors",
  "homepage": "https://github.com/webrtc-node/webrtc/tree/main/packages/stats#readme",
  "bugs": {
    "url": "https://github.com/webrtc-node/webrtc/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/webrtc-node/webrtc.git",
    "directory": "packages/stats"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "webrtc",
    "node",
    "statistics",
    "telemetry",
    "libdatachannel"
  ],
  "main": "lib/index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "require": "./lib/index.js",
      "import": "./lib/index.js",
      "default": "./lib/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "lib",
    "index.d.ts"
  ],
  "scripts": {
    "build": "node --check lib/index.js",
    "check": "biome check .",
    "format": "biome format --write .",
    "package:check": "npm pack --dry-run --json",
    "test": "node --test test/stats.test.js",
    "types:check": "tsc -p tsconfig.json"
  },
  "peerDependencies": {
    "@webrtc-node/webrtc": "^0.2.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@webrtc-node/webrtc": "0.2.1",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MPL-2.0"
}
